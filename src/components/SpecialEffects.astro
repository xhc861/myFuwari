---
// 特效管理组件
import ConfettiEffect from './ConfettiEffect.svelte';
import FestivalLanterns from './FestivalLanterns.svelte';
import GrayscaleFilter from './GrayscaleFilter.svelte';
import ParticlesBackground from './ParticlesBackground.svelte';
import ShootingStars from './ShootingStars.svelte';
import SpotlightEffect from './SpotlightEffect.svelte';
---

<!-- 五彩纸屑效果（点击触发） -->
<ConfettiEffect client:only="svelte" />

<!-- 节日灯笼（手动控制） -->
<FestivalLanterns client:only="svelte" show={false} />

<!-- 纪念日黑白滤镜 -->
<GrayscaleFilter client:only="svelte" />

<!-- 粒子背景 -->
<ParticlesBackground client:only="svelte" />

<!-- 流星效果 -->
<ShootingStars client:only="svelte" />

<!-- 聚光灯效果 -->
<SpotlightEffect client:only="svelte" />
